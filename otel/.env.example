# Auto-instrumentacao Node.js (zero-code)
# Adicionar estas env vars no docker-compose da aplicacao

OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://10.0.0.X:4318
OTEL_NODE_RESOURCE_DETECTORS=env,host,os
OTEL_SERVICE_NAME=meu-servico
NODE_OPTIONS=--require @opentelemetry/auto-instrumentations-node/register

# Pacotes necessarios no package.json da aplicacao:
# npm install @opentelemetry/api @opentelemetry/auto-instrumentations-node
