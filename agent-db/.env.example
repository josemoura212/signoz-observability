# IP do servidor onde roda o SigNoz
SIGNOZ_ENDPOINT=10.0.0.X

OTELCOL_CONTRIB_VERSION=0.146.0

# PostgreSQL - conectar direto no PG, não no PgBouncer
PG_HOST=host.docker.internal
PG_PORT=5432
PG_MONITOR_USER=signoz_monitor
PG_MONITOR_PASSWORD=changeme
PG_DATABASE=unnichat

# Caminho dos logs do PG no host
# Se PG roda em Docker: /var/lib/docker/volumes/<volume>/_data/pg_log
# Se PG roda direto no host: /var/lib/postgresql/17/main/pg_log
PG_LOG_PATH=/var/lib/postgresql/17/main/pg_log

# Identificação do servidor PG (para distinguir primário/réplica no dashboard)
# Usar o mesmo service.name para agregar, e postgresql.role para filtrar
PG_SERVICE_NAME=postgresql
PG_ROLE=primary
