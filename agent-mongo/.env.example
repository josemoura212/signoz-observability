# IP do servidor onde roda o SigNoz
SIGNOZ_ENDPOINT=10.0.0.X

OTELCOL_CONTRIB_VERSION=0.146.0

# MongoDB - criar usuario com role clusterMonitor
MONGO_ENDPOINT=host.docker.internal:27017
MONGO_MONITOR_USER=signoz_monitor
MONGO_MONITOR_PASSWORD=changeme

# Caminho dos logs do MongoDB no host
# Se Mongo roda em Docker: /var/lib/docker/volumes/<volume>/_data/log
# Se Mongo roda direto no host: /var/log/mongodb
MONGO_LOG_PATH=/var/log/mongodb
