# IP do servidor onde roda o SigNoz
SIGNOZ_ENDPOINT=10.0.0.X

OTELCOL_CONTRIB_VERSION=0.146.0

# ClickHouse Prometheus metrics endpoint (porta 9363)
CLICKHOUSE_ENDPOINT=host.docker.internal:9363

# Caminho dos logs do ClickHouse no host
# Se CH roda em Docker: usar o volume de logs montado
# Se CH roda direto no host: /var/log/clickhouse-server
CLICKHOUSE_LOG_PATH=/var/log/clickhouse-server
